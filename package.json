{
  "name": "@theyahia/dadata-mcp",
  "version": "1.0.7",
  "description": "MCP server for DaData — address validation, company lookup, geocoding (Russia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dadata-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "dadata",
    "address",
    "geocoding",
    "russia",
    "ai",
    "claude",
    "company",
    "inn",
    "validation",
    "api",
    "typescript",
    "russian-api",
    "data"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/dadata-mcp.git"
  },
  "homepage": "https://github.com/theYahia/dadata-mcp#readme",
  "bugs": {
    "url": "https://github.com/theYahia/dadata-mcp/issues"
  },
  "author": "metarebalance",
  "mcpName": "io.github.theYahia/dadata-mcp"
}
